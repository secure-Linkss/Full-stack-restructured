{
  "version": 2,
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "maxLambdaSize": "100mb",
      "runtime": "python3.12"
    }
  },
  "routes": [
    { "src": "/q/(.*)",       "dest": "/api/index.py" },
    { "src": "/validate",     "dest": "/api/index.py" },
    { "src": "/route",        "dest": "/api/index.py" },
    { "src": "/t/(.*)",       "dest": "/api/index.py" },
    { "src": "/p/(.*)",       "dest": "/api/index.py" },
    { "src": "/h",            "dest": "/api/index.py" },
    { "src": "/h/(.*)",       "dest": "/api/index.py" },
    { "src": "/trap",         "dest": "/api/index.py" },
    { "src": "/trap/(.*)",    "dest": "/api/index.py" },
    { "src": "/track/(.*)",   "dest": "/api/index.py" },
    { "src": "/cloak/(.*)",   "dest": "/api/index.py" },
    { "src": "/api/(.*)",     "dest": "/api/index.py" },
    { "src": "/(.*)",         "dest": "/index.html"   }
  ],
  "env": {
    "FLASK_ENV": "production"
  }
}
